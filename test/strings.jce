echo "Here comes another quote: 'Lorem ipsum'. This didn't require escaping!\n"

echo "multiple" "strings" "to" "echo" "\n"

echo "Escape sequences work: \u2764\ufe0f"
echo 'Escape sequences are printed as-is: \u2764\ufe0f'

